# X API (OAuth 1.0a User Context)
# Get these from https://developer.twitter.com/en/portal/dashboard
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_USER_ID=               # Your numeric X user ID (needed for timeline endpoint)

# AI Provider (OpenAI-compatible)
# LM Studio (local):    http://localhost:1234/v1  / not-needed
# Ollama (local):       http://localhost:11434/v1  / not-needed
# OpenRouter (cloud):   https://openrouter.ai/api/v1  / sk-or-...
AI_BASE_URL=http://localhost:1234/v1
AI_MODEL=local-model
AI_API_KEY=not-needed

# Service
SERVICE_PORT=3000
SERVICE_HOST=0.0.0.0

# Bot Defaults (all configurable at runtime via dashboard)
POLL_INTERVAL_MINUTES=480     # How often to read timeline (default: 8h to stay within free tier ~100 reads/month)
POST_FREQUENCY_HOURS=2.5      # How often to generate an original post
REPLY_PROBABILITY=0.4         # Probability (0-1) of replying when reply cycle runs
MAX_POSTS_PER_DAY=10          # Max original posts per day
MAX_REPLIES_PER_DAY=6         # Max replies per day
ACTIVE_HOURS_START=8          # Only post/reply between these hours (local time)
ACTIVE_HOURS_END=23
MAX_TWEET_LENGTH=280          # 280 standard | 4000 X Premium | 25000 X Premium+
ENABLE_THREADS=true           # Split long posts into reply chains instead of truncating

# Optional: Override the bot's persona/tone (also configurable at runtime)
# PERSONA_PROMPT=You are a thoughtful tech-savvy person sharing insights on software, AI, and tech culture.
